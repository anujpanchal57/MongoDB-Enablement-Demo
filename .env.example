# =============================================================================
# MongoDB on AWS — Demonstration App : Environment Configuration
# Copy this file to `.env` (repo root) and fill in real values.
# The backend reads these via pydantic-settings; the frontend reads NEXT_PUBLIC_*.
# =============================================================================

# ----- MongoDB Atlas ---------------------------------------------------------
# Atlas connection string (SRV). The cluster should run on AWS.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Database that holds the sample_mflix.embedded_movies collection.
MONGODB_DB=sample_mflix
MONGODB_COLLECTION=embedded_movies

# Atlas Search / Vector Search index names (created by scripts/seed_search_indexes.py)
ATLAS_TEXT_INDEX=default
ATLAS_VECTOR_INDEX=vector_index

# ----- Voyage AI (embeddings) ------------------------------------------------
# https://docs.voyageai.com/  — used for vector + hybrid search query/doc embeddings.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
VOYAGE_EMBEDDING_DIM=1024
# Field on embedded_movies that stores the Voyage embedding (added by the seed script).
VECTOR_FIELD=plot_embedding_voyage

# ----- Feature 4: Atlas automated embedding ----------------------------------
# Atlas-managed embedding model + collection/index created by the demo's setup.
AUTOEMBED_COLLECTION=auto_embedded_destinations
AUTOEMBED_INDEX=autoembed_vector_index
AUTOEMBED_PATH=description
# Atlas-managed auto-embed model. Supported: voyage-4, voyage-4-large, voyage-4-lite, voyage-code-3.
AUTOEMBED_MODEL=voyage-4

# ----- Feature 2: agentic memory (LangGraph + MongoDB) -----------------------
MEMORY_DB=agentic_memory
MEMORY_CHECKPOINT_COLLECTION=thread_checkpoints
MEMORY_STORE_COLLECTION=long_term_memories

# ----- AWS (Bedrock chat for Feature 2 agent) --------------------------------
# Credential options (pick ONE):
#  a) Static IAM user keys: set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY.
#  b) TEMPORARY creds (AWS SSO / assumed role / STS): set all THREE keys below,
#     INCLUDING AWS_SESSION_TOKEN — without it Bedrock returns
#     "UnrecognizedClientException: The security token ... is invalid".
#  c) Named profile: leave the keys blank and set AWS_PROFILE.
#  d) Leave everything blank to use the default chain (e.g. IAM role on Amplify).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=
# Bedrock model id for chat/agent (Feature 2). Requires model access enabled in
# the Bedrock console for this region. Embeddings stay on Voyage.
BEDROCK_CHAT_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# ----- Backend server --------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated origins allowed by CORS (the Next.js dev/prod origins).
CORS_ORIGINS=http://localhost:3000

# ----- Frontend --------------------------------------------------------------
# Base URL the Next.js app uses to reach FastAPI.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
